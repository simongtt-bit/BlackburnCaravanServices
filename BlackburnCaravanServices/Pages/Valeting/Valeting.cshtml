@page
@model ValetingModel
@{
    ViewData["Title"] = "Caravan Valeting";
}

<section class="page-hero">
    <div class="container">
        <p class="eyebrow">Caravan valeting</p>
        <h1>Professional caravan valeting in Blackburn</h1>
        <p class="page-intro">
            Keep your caravan looking its best with professional exterior and interior valeting services.
        </p>
    </div>
</section>

<section class="section">
    <div class="container service-detail-grid">
        <div>
            <h2>Interior and exterior caravan cleaning</h2>
            <p class="section-intro">
                Whether your caravan needs a seasonal refresh, a deep clean before sale or a full valet after time in storage,
                Blackburn Caravan Services can help bring it back to a clean, presentable condition.
            </p>

            <div class="feature-list">
                <div>Exterior washing</div>
                <div>Interior cleaning</div>
                <div>Pre-sale preparation</div>
                <div>Seasonal refreshes</div>
                <div>Storage clean-ups</div>
                <div>General valeting</div>
            </div>

            <div class="hero-actions">
                <a asp-page="/Contact" class="button button-primary">Book a valet</a>
                <a href="tel:01254957013" class="button button-secondary">Call 01254 957013</a>
            </div>
        </div>

        <aside class="contact-panel">
            <h3>Service & sales department</h3>
            <p><strong>Phone:</strong><br />01254 957013</p>
            <p><strong>Email:</strong><br />info@blackburncaravanservices.co.uk</p>
            <p><strong>Address:</strong><br />Unit D2, Percliff Way, Blackburn, BB1 5PF</p>
        </aside>
    </div>
</section>