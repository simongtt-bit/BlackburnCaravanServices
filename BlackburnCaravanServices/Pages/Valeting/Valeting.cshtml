@page
@model ValetingModel
@using BlackburnCaravanServices.Models
@{
    ViewData["Title"] = "Caravan Valeting";

    var heroModel = new PageHeroModel(
        "Valeting",
        "Professional caravan valeting",
        "Keep your caravan clean, fresh and well presented with interior and exterior valeting from an experienced local team.",
        new[]
        {
            new PageHeroFeatureModel("Exterior cleaning", "Careful cleaning to improve the look and presentation of your caravan."),
            new PageHeroFeatureModel("Interior refresh", "Interior cleaning to help your caravan feel fresh, tidy and ready to use."),
            new PageHeroFeatureModel("Pre-sale preparation", "Ideal before holidays, storage, viewings or selling your caravan.")
        });
    
    var ctaModel = new CallToActionModel(
        "Need a valet?",
        "Book a professional caravan valet",
        "Get your caravan cleaned, refreshed and ready for the season, storage or sale.",
        "Book a valet",
        "/Contact/Contact");
    
}

<partial name="_PageHero" model="heroModel" />

<section class="section">
    <div class="container service-detail-grid">
        <div>
            <h2>Interior and exterior caravan cleaning</h2>

            <p class="section-intro">
                Whether your caravan needs a seasonal refresh, a deep clean before sale or a full valet after time in storage,
                Blackburn Caravan Services can help bring it back to a clean, presentable condition.
            </p>

            <div class="feature-list">
                <div>Exterior washing</div>
                <div>Interior cleaning</div>
                <div>Pre-sale preparation</div>
                <div>Seasonal refreshes</div>
                <div>Storage clean-ups</div>
                <div>General valeting</div>
            </div>

            <div class="hero-actions">
                <a asp-page="/Contact/Contact" class="button button-primary">
                    Book a valet
                </a>

                <a href="tel:01254957013" class="button button-secondary">
                    Call 01254 957013
                </a>
            </div>
        </div>

        <aside class="contact-panel">
            <h3>Service & sales department</h3>

            <p>
                <strong>Phone:</strong><br />
                01254 957013
            </p>

            <p>
                <strong>Email:</strong><br />
                info@blackburncaravanservices.co.uk
            </p>

            <p>
                <strong>Address:</strong><br />
                Unit D2, Percliff Way,<br />
                Blackburn, BB1 5PF
            </p>
        </aside>
    </div>
</section>
<partial name="_CallToAction" model="ctaModel" />