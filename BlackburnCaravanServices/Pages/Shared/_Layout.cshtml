<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - BlackburnCaravanServices</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<header class="site-header">
    <div class="container header-inner">

        <a class="brand" asp-page="/Index">
            <span class="brand-text">
                Blackburn Caravan Services
            </span>

        </a>

        <nav class="site-nav">
            <a asp-page="/Index">Home</a>
            <a asp-page="/Servicing/Servicing">Servicing</a>
            <a asp-page="/Repairs/Repairs">Repairs</a>
            <a asp-page="/CaravansForSale/CaravansForSale">Used Caravans</a>
            <a asp-page="/SellYourCaravan/SellYourCaravan">Sell Your Caravan</a>
            <a asp-page="/Valeting/Valeting">Valeting</a>
            <a asp-page="/Contact/Contact" class="nav-cta">Contact</a>
        </nav>

    </div>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="site-footer">
    <div class="container footer-grid">

        <div>
            <h3>Blackburn Caravan Services</h3>

            <p>
                Professional caravan servicing, repairs, valeting and used caravan sales
                from our workshops in Blackburn.
            </p>
        </div>

        <div>
            <h4>Services</h4>

            <ul class="footer-links">
                <li><a asp-page="/Servicing/Servicing">Servicing</a></li>
                <li><a asp-page="/Repairs/Repairs">Repairs</a></li>
                <li><a asp-page="/Valeting/Valeting">Valeting</a></li>
                <li><a asp-page="/CaravansForSale/CaravansForSale">Used Caravans</a></li>
            </ul>
        </div>

        <div>
            <h4>Contact</h4>

            <p>
                Unit D2, Percliff Way<br />
                Blackburn<br />
                BB1 5PF
            </p>

            <p>
                <a href="tel:01254957013">01254 957013</a><br />
                <a href="mailto:info@blackburncaravanservices.co.uk">
                    info@blackburncaravanservices.co.uk
                </a>
            </p>
        </div>

    </div>

    <div class="footer-bottom">
        <div class="container">
            © @DateTime.Now.Year Blackburn Caravan Services. All rights reserved.
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>