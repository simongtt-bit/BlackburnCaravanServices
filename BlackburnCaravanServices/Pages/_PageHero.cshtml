@model BlackburnCaravanServices.Models.PageHeroModel

<section class="page-hero page-hero-premium">
    <div class="container page-hero-inner">
        <div class="page-hero-content">
            <p class="eyebrow">@Model.Eyebrow.ToUpper()</p>

            <h1>@Model.Title</h1>

            <p class="page-intro">
                @Model.Description
            </p>
        </div>
    </div>
</section>

@if (Model.Features.Any())
{
    <section class="hero-feature-strip">
        <div class="container hero-feature-grid">

            @foreach (var feature in Model.Features)
            {
                <article class="hero-feature-item">
                    <div class="hero-feature-icon">
                        ✓
                    </div>

                    <div>
                        <h3>@feature.Title</h3>
                        <p>@feature.Text</p>
                    </div>
                </article>
            }

        </div>
    </section>
}