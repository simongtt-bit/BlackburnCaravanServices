@page
@model ServicingModel
@using BlackburnCaravanServices.Models
@{
    ViewData["Title"] = "Caravan Servicing";

    var heroModel = new PageHeroModel(
        "Servicing",
        "Caravan servicing you can rely on",
        "Keep your caravan safe, reliable and ready for the road with servicing from an experienced local team.",
        new[]
        {
            new PageHeroFeatureModel("Full workmanship service", "Comprehensive servicing carried out by experienced technicians."),
            new PageHeroFeatureModel("Safety checks", "Gas, electrical and mechanical systems thoroughly inspected."),
            new PageHeroFeatureModel("Peace of mind", "Professional servicing to keep your caravan adventure ready.")
        });
}

<partial name="_PageHero" model="heroModel" />

<section class="section">
    <div class="container service-detail-grid">
        <div>
            <h2>Servicing, electrical and gas work</h2>

            <p class="section-intro">
                Blackburn Caravan Services has a dedicated workshop for servicing, electrical and gas work.
                Their team has over 20 years' experience in the caravan and leisure industry.
            </p>

            <div class="feature-list">
                <div>Full caravan servicing</div>
                <div>Electrical checks</div>
                <div>Gas checks</div>
                <div>Pre-season inspections</div>
                <div>General maintenance</div>
                <div>Friendly, practical advice</div>
            </div>

            <div class="hero-actions">
                <a asp-page="/Contact/Contact" class="button button-primary">
                    Book a service
                </a>

                <a href="tel:01254957013" class="button button-secondary">
                    Call 01254 957013
                </a>
            </div>
        </div>

        <aside class="contact-panel">
            <h3>Service & sales department</h3>

            <p>
                <strong>Phone:</strong><br />
                01254 957013
            </p>

            <p>
                <strong>Email:</strong><br />
                info@blackburncaravanservices.co.uk
            </p>

            <p>
                <strong>Address:</strong><br />
                Unit D2, Percliff Way,<br />
                Blackburn, BB1 5PF
            </p>
        </aside>
    </div>
</section>