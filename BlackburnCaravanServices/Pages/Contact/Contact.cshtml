@page
@model ContactModel
@using BlackburnCaravanServices.Models
@{
    ViewData["Title"] = "Contact";

    var heroModel = new PageHeroModel(
        "Contact us",
        "Speak to our caravan team",
        "Contact our servicing, sales or repairs team, or visit our caravan workshops in Blackburn.",
        new[]
        {
            new PageHeroFeatureModel("Service and sales", "Call 01254 957013 for servicing, sales and general enquiries."),
            new PageHeroFeatureModel("Repairs department", "Call 01254 241693 for repairs, damp work and bodywork enquiries."),
            new PageHeroFeatureModel("Visit our workshop", "Find us at Unit D2, Percliff Way, Blackburn, BB1 5PF.")
        });
}

<partial name="_PageHero" model="heroModel" />

<section class="section">
    <div class="container service-detail-grid">
        <div>
            <h2>Contact Blackburn Caravan Services</h2>

            <p class="section-intro">
                Whether you need to book a service, arrange a repair, enquire about a used caravan
                or discuss selling your caravan, our team will be happy to help.
            </p>

            <div class="feature-list">
                <div>Caravan servicing</div>
                <div>Repairs and damp work</div>
                <div>Used caravan sales</div>
                <div>Sell your caravan</div>
                <div>Valeting</div>
                <div>General enquiries</div>
            </div>
        </div>

        <aside class="contact-panel">
            <h3>Contact details</h3>

            <p><strong>Service & sales:</strong><br />01254 957013</p>
            <p><strong>Repairs:</strong><br />01254 241693</p>
            <p><strong>Email:</strong><br />info@blackburncaravanservices.co.uk</p>
            <p><strong>Address:</strong><br />Unit D2, Percliff Way,<br />Blackburn, BB1 5PF</p>

            <div class="hero-actions">
                <a href="tel:01254957013" class="button button-primary">
                    Service & sales: 01254 957013
                </a>

                <a href="tel:01254241693" class="button button-secondary">
                    Repairs: 01254 241693
                </a>
            </div>
        </aside>
    </div>
</section>

<section class="section section-muted">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Send an enquiry</p>
            <h2>Tell us how we can help</h2>

            <p class="section-intro">
                Complete the form below and a member of our team will get back to you as soon as possible.
            </p>
        </div>

        <form class="contact-form"
              action="https://formspree.io/f/mbdvpljz"
              method="POST">

            <div class="form-grid">
                <div class="form-row">
                    <label for="name">Name</label>
                    <input id="name" name="name" type="text" placeholder="Your name" required />
                </div>

                <div class="form-row">
                    <label for="phone">Phone number</label>
                    <input id="phone" name="phone" type="tel" placeholder="Your phone number" />
                </div>

                <div class="form-row">
                    <label for="email">Email address</label>
                    <input id="email" name="email" type="email" placeholder="Your email address" required />
                </div>

                <div class="form-row">
                    <label for="type">Enquiry type</label>
                    <select id="type" name="enquiryType" required>
                        <option value="">Select an enquiry type</option>
                        <option value="Servicing">Servicing</option>
                        <option value="Repairs">Repairs</option>
                        <option value="Used caravans">Used caravans</option>
                        <option value="Sell your caravan">Sell your caravan</option>
                        <option value="Valeting">Valeting</option>
                        <option value="General enquiry">General enquiry</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <label for="message">Message</label>
                <textarea id="message"
                  name="message"
                  rows="6"
                  placeholder="Tell us how we can help..."
                  required></textarea>
            </div>

            <input type="hidden" name="_subject" value="New enquiry from Blackburn Caravan Services website" />
            <input
                type="hidden"
                name="_next"
                value="https://localhost:7040/ThankYou" />

            <button type="submit" class="button button-primary">
                Send enquiry
            </button>
        </form>
    </div>
</section>

<section class="section">
    <div class="container service-detail-grid">
        <div>
            <p class="eyebrow">Opening hours</p>
            <h2>Visit our Blackburn workshops</h2>

            <div class="opening-hours">
                <div><strong>Monday</strong><span>9:00am – 4:30pm</span></div>
                <div><strong>Tuesday</strong><span>9:00am – 4:30pm</span></div>
                <div><strong>Wednesday</strong><span>9:00am – 4:30pm</span></div>
                <div><strong>Thursday</strong><span>9:00am – 4:30pm</span></div>
                <div><strong>Friday</strong><span>9:00am – 4:30pm</span></div>
                <div><strong>Saturday</strong><span>By appointment</span></div>
                <div><strong>Sunday</strong><span>Closed</span></div>
            </div>
        </div>

        <div class="map-card">
            <iframe
                title="Blackburn Caravan Services map"
                src="https://www.google.com/maps?q=Unit%20D2%2C%20Percliff%20Way%2C%20Blackburn%2C%20BB1%205PF&output=embed"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>
    </div>
</section>