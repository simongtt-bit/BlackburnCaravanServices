@page
@model RepairsModel
@{
    ViewData["Title"] = "Caravan Repairs";
}

<section class="page-hero">
    <div class="container">
        <p class="eyebrow">Caravan repairs</p>
        <h1>Specialist caravan repairs in Blackburn</h1>
        <p class="page-intro">
            From damp repairs and bodywork to floor delamination and internal woodwork, our experienced team can help get your caravan back to its best.
        </p>
    </div>
</section>

<section class="section">
    <div class="container service-detail-grid">
        <div>
            <h2>Repairs carried out by experienced specialists</h2>
            <p class="section-intro">
                Blackburn Caravan Services has a dedicated repairs workshop for structural, internal and external caravan repair work.
                Whether you need damp damage repaired, body panels restored or internal fittings repaired, we provide clear advice and practical solutions.
            </p>

            <div class="feature-list">
                <div>Damp repairs</div>
                <div>Bodywork repairs</div>
                <div>Floor delamination</div>
                <div>Internal woodwork repairs</div>
                <div>Insurance repair work</div>
                <div>General caravan repairs</div>
            </div>

            <div class="hero-actions">
                <a asp-page="/Contact" class="button button-primary">Request a repair quote</a>
                <a href="tel:01254241693" class="button button-secondary">Call 01254 241693</a>
            </div>
        </div>

        <aside class="contact-panel">
            <h3>Repairs department</h3>
            <p><strong>Phone:</strong><br />01254 241693</p>
            <p><strong>Email:</strong><br />info@blackburncaravanservices.co.uk</p>
            <p><strong>Address:</strong><br />Unit D2, Percliff Way, Blackburn, BB1 5PF</p>
        </aside>
    </div>
</section>

<section class="section section-muted">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">What we repair</p>
            <h2>Reliable repair work for common caravan issues</h2>
        </div>

        <div class="service-grid">
            <article class="service-card">
                <h3>Damp repairs</h3>
                <p>
                    Damp can quickly lead to further damage if left untreated. We can inspect the affected areas and advise on the best repair route.
                </p>
            </article>

            <article class="service-card">
                <h3>Bodywork repairs</h3>
                <p>
                    Repairs for external damage, panels, trims and general caravan bodywork issues.
                </p>
            </article>

            <article class="service-card">
                <h3>Internal repairs</h3>
                <p>
                    Woodwork, fittings, floors and other internal repair work carried out by an experienced team.
                </p>
            </article>
        </div>
    </div>
</section>