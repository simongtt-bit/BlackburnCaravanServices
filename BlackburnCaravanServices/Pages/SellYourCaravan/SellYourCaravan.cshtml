@page
@model SellYourCaravanModel
@using BlackburnCaravanServices.Models
@{
    ViewData["Title"] = "Sell Your Caravan";

    var heroModel = new PageHeroModel(
        "Sell your caravan",
        "Sell your caravan with confidence",
        "We offer a simple, friendly and honest service for customers looking to sell or part exchange their caravan.",
        new[]
        {
            new PageHeroFeatureModel("Free valuation", "Get a fair, no-obligation valuation for your caravan."),
            new PageHeroFeatureModel("Quick and easy", "We make the selling process straightforward and stress-free."),
            new PageHeroFeatureModel("Hassle free", "Avoid the uncertainty and inconvenience of private sales.")
        });
}

<partial name="_PageHero" model="heroModel" />

<section class="section">
    <div class="container service-detail-grid">
        <div>
            <h2>A simple, hassle-free process</h2>

            <p class="section-intro">
                Avoid the stress of private sales and let our experienced team help.
                We can assess your caravan and discuss the options available, whether
                you're looking to sell outright or part exchange against another model.
            </p>

            <div class="feature-list">
                <div>Friendly advice</div>
                <div>Fair valuations</div>
                <div>Part exchange options</div>
                <div>No private sale hassle</div>
                <div>Quick decisions</div>
                <div>Local family business</div>
            </div>

            <div class="hero-actions">
                <a asp-page="/Contact/Contact" class="button button-primary">
                    Get a valuation
                </a>

                <a href="tel:01254957013" class="button button-secondary">
                    Call 01254 957013
                </a>
            </div>
        </div>

        <aside class="contact-panel">
            <h3>Service & sales department</h3>

            <p>
                <strong>Phone:</strong><br />
                01254 957013
            </p>

            <p>
                <strong>Email:</strong><br />
                info@blackburncaravanservices.co.uk
            </p>

            <p>
                <strong>Address:</strong><br />
                Unit D2, Percliff Way,<br />
                Blackburn, BB1 5PF
            </p>
        </aside>
    </div>
</section>

<section class="section section-muted">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">How it works</p>
            <h2>Three simple steps</h2>
        </div>

        <div class="service-grid">
            <article class="service-card">
                <h3>1. Get in touch</h3>
                <p>
                    Contact our team with details of your caravan, including age,
                    make, model and condition.
                </p>
            </article>

            <article class="service-card">
                <h3>2. Receive a valuation</h3>
                <p>
                    We'll discuss the options available and provide a fair,
                    honest assessment.
                </p>
            </article>

            <article class="service-card">
                <h3>3. Complete the sale</h3>
                <p>
                    Once everything is agreed, we'll make the process as smooth
                    and straightforward as possible.
                </p>
            </article>
        </div>
    </div>
</section>